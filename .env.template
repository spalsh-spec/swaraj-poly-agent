# ── swaraj-poly-agent environment template ──────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.

# Polygon private key (0x-prefixed, controls your Polymarket CLOB account)
POLY_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Polymarket CLOB API credentials (from https://polymarket.com/settings/api-keys)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Chain: 137 = Polygon mainnet
POLY_CHAIN_ID=137

# Risk parameters
BANKROLL_USDC=100.0        # total capital to deploy
MAX_EXPOSURE=0.25          # max fraction deployed simultaneously
MAX_SINGLE_BET=0.10        # max fraction per single bet
MAX_DAILY_LOSS=20.0        # pause agent if daily PnL < -$20
MAX_POSITIONS=5            # max concurrent open positions

# Signal thresholds
MIN_HURST=0.55             # only trade H > 0.55 (persistent regimes)
MIN_KELLY=0.005            # minimum half-Kelly fraction to bother
MIN_VOLUME=5000            # min 24h volume in USDC

# Timing
SCAN_INTERVAL=900          # seconds between market scans (15 min)
POLL_INTERVAL=60           # seconds between fill-check polls

# Safety gate — keep True until you've verified everything manually
DRY_RUN=True
