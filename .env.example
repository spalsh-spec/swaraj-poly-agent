# ── Polymarket credentials ─────────────────────────────────────────────────
POLY_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
POLY_API_KEY=your_polymarket_api_key
POLY_API_SECRET=your_polymarket_api_secret
POLY_API_PASSPHRASE=your_polymarket_api_passphrase

# ── Risk parameters ────────────────────────────────────────────────────────
BANKROLL_USDC=100.0
MAX_EXPOSURE=0.25
MAX_SINGLE_BET=0.10
MAX_DAILY_LOSS=20.0
MAX_POSITIONS=5

# ── Signal thresholds ──────────────────────────────────────────────────────
MIN_HURST=0.55
MIN_KELLY=0.02
MIN_VOLUME=5000

# ── Timing ────────────────────────────────────────────────────────────────
SCAN_INTERVAL=900
POLL_INTERVAL=60
ORDER_FILL_TIMEOUT=300

# ── Safety ────────────────────────────────────────────────────────────────
DRY_RUN=True

# ── Daily digest email ────────────────────────────────────────────────────
# Leave blank to write HTML file to dashboard/ instead of emailing
DIGEST_EMAIL_TO=you@gmail.com
DIGEST_EMAIL_FROM=swaraj@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_gmail_app_password
